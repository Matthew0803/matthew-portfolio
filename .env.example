# App Configuration
VITE_APP_TITLE=Matthew's Portfolio
VITE_APP_LOGO=/logo.png

# Analytics (Optional - leave empty if not using Umami analytics)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Admin panel (set to true locally to enable /admin routes)
VITE_ADMIN_ENABLED=false
VITE_PAGES_ENABLED=true

# Server — write API guard (set to false on prod to block POST/PUT/DELETE)
ALLOW_WRITES=true

# Persistent volume paths (Railway/Docker — leave empty for local dev)
DATA_DIR=
UPLOADS_DIR=
SQLITE_DB_PATH=
